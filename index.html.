<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Quiz Mentalidad · Roger Jofre</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Work+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --mint: #9BE7DB;
    --mint-light: #c8f4ee;
    --mint-dark: #6dd4c4;
    --tangerine: #F3843C;
    --coral: #FF6A40;
    --lime: #ACCD28;
    --white: #ffffff;
    --dark: #1a1a1a;
    --dark-mid: #2d2d2d;
    --text-muted: #5a5a5a;
    --card-bg: rgba(255,255,255,0.92);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html, body {
    min-height: 100vh;
    font-family: 'Work Sans', sans-serif;
    background: var(--mint);
    overflow-x: hidden;
  }

  /* ANIMATED BACKGROUND */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: 
      radial-gradient(ellipse 80% 60% at 15% 20%, rgba(243,132,60,0.18) 0%, transparent 60%),
      radial-gradient(ellipse 60% 80% at 85% 80%, rgba(172,205,40,0.15) 0%, transparent 55%),
      radial-gradient(ellipse 50% 50% at 50% 50%, rgba(255,255,255,0.25) 0%, transparent 70%);
    z-index: 0;
    pointer-events: none;
  }

  /* DECORATIVE CIRCLES */
  body::after {
    content: '';
    position: fixed;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    border: 2px solid rgba(255,255,255,0.35);
    top: -150px;
    left: -150px;
    z-index: 0;
    pointer-events: none;
  }

  .deco-circle {
    position: fixed;
    border-radius: 50%;
    border: 1.5px solid rgba(255,255,255,0.25);
    pointer-events: none;
    z-index: 0;
  }
  .deco-circle-1 { width: 400px; height: 400px; bottom: -100px; right: -100px; }
  .deco-circle-2 { width: 200px; height: 200px; top: 40%; right: 5%; border-color: rgba(243,132,60,0.3); }

  /* WRAPPER */
  #app {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  /* CARD */
  .card {
    background: var(--card-bg);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-radius: 28px;
    padding: 52px 52px 44px;
    max-width: 620px;
    width: 100%;
    box-shadow: 
      0 4px 24px rgba(0,0,0,0.08),
      0 1px 0 rgba(255,255,255,0.8) inset;
    animation: cardIn 0.5s cubic-bezier(0.34,1.56,0.64,1);
  }

  @keyframes cardIn {
    from { opacity: 0; transform: translateY(30px) scale(0.97); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  .card-fade {
    animation: fadeSwitch 0.3s ease;
  }
  @keyframes fadeSwitch {
    0% { opacity: 0; transform: translateX(20px); }
    100% { opacity: 1; transform: translateX(0); }
  }

  /* LOGO */
  .logo-wrap {
    display: flex;
    justify-content: center;
    margin-bottom: 32px;
  }
  .logo-wrap img {
    height: 64px;
    width: auto;
    object-fit: contain;
  }

  /* PROGRESS BAR */
  .progress-wrap {
    margin-bottom: 32px;
  }
  .progress-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
  }
  .progress-label {
    font-family: 'Work Sans', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--tangerine);
  }
  .progress-count {
    font-family: 'Work Sans', sans-serif;
    font-size: 12px;
    color: var(--text-muted);
    font-weight: 500;
  }
  .progress-bar-bg {
    width: 100%;
    height: 5px;
    background: rgba(0,0,0,0.08);
    border-radius: 99px;
    overflow: hidden;
  }
  .progress-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--tangerine), var(--coral));
    border-radius: 99px;
    transition: width 0.5s cubic-bezier(0.34,1.56,0.64,1);
  }

  /* TYPOGRAPHY */
  h1.display {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(28px, 5vw, 40px);
    line-height: 1.15;
    color: var(--dark);
    margin-bottom: 14px;
  }
  h1.display em {
    font-style: italic;
    color: var(--tangerine);
  }

  .subtitle {
    font-family: 'Work Sans', sans-serif;
    font-size: 17px;
    font-weight: 500;
    color: var(--tangerine);
    letter-spacing: -0.01em;
    margin-bottom: 12px;
  }

  .intro-text {
    font-family: 'Work Sans', sans-serif;
    font-size: 15.5px;
    line-height: 1.7;
    color: var(--text-muted);
    margin-bottom: 32px;
  }

  .question-text {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(20px, 4vw, 27px);
    line-height: 1.3;
    color: var(--dark);
    margin-bottom: 32px;
    min-height: 72px;
  }

  /* ANSWER OPTIONS */
  .options {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 16px;
  }

  .option-btn {
    display: flex;
    align-items: center;
    gap: 14px;
    background: rgba(155,231,219,0.15);
    border: 1.5px solid rgba(155,231,219,0.5);
    border-radius: 14px;
    padding: 16px 20px;
    cursor: pointer;
    transition: all 0.2s ease;
    text-align: left;
    font-family: 'Work Sans', sans-serif;
    font-size: 15px;
    font-weight: 500;
    color: var(--dark);
    width: 100%;
  }

  .option-btn:hover {
    background: rgba(243,132,60,0.08);
    border-color: var(--tangerine);
    transform: translateX(4px);
  }

  .option-btn.selected {
    background: var(--tangerine);
    border-color: var(--tangerine);
    color: white;
    transform: translateX(4px);
  }

  .option-dot {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    border: 2px solid currentColor;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 700;
    opacity: 0.6;
  }

  .option-btn.selected .option-dot {
    background: white;
    color: var(--tangerine);
    opacity: 1;
  }

  /* BUTTONS */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: linear-gradient(135deg, var(--tangerine), var(--coral));
    color: white;
    border: none;
    border-radius: 14px;
    padding: 17px 36px;
    font-family: 'Work Sans', sans-serif;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.25s ease;
    width: 100%;
    box-shadow: 0 4px 20px rgba(243,132,60,0.35);
    letter-spacing: -0.01em;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(243,132,60,0.45);
  }

  .btn-primary:active {
    transform: translateY(0);
  }

  .btn-primary:disabled {
    opacity: 0.4;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
  }

  .btn-ghost {
    background: transparent;
    border: 1.5px solid rgba(0,0,0,0.12);
    color: var(--text-muted);
    border-radius: 12px;
    padding: 13px 24px;
    font-family: 'Work Sans', sans-serif;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    width: 100%;
    margin-top: 10px;
  }
  .btn-ghost:hover { border-color: var(--tangerine); color: var(--tangerine); }

  /* TAGS */
  .tag {
    display: inline-block;
    background: rgba(172,205,40,0.2);
    color: #6a7f10;
    font-size: 11.5px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 5px 12px;
    border-radius: 99px;
    margin-bottom: 20px;
  }

  /* TIME ESTIMATE */
  .time-badge {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: var(--text-muted);
    font-weight: 500;
    margin-top: 20px;
  }
  .time-badge span { opacity: 0.6; font-size: 15px; }

  /* EMAIL SCREEN */
  .email-section { margin-bottom: 10px; }
  .email-label {
    display: block;
    font-size: 13px;
    font-weight: 600;
    color: var(--dark-mid);
    margin-bottom: 8px;
    letter-spacing: 0.02em;
  }
  .email-input {
    width: 100%;
    border: 1.5px solid rgba(0,0,0,0.12);
    border-radius: 12px;
    padding: 15px 18px;
    font-family: 'Work Sans', sans-serif;
    font-size: 15px;
    color: var(--dark);
    outline: none;
    background: rgba(255,255,255,0.8);
    transition: border-color 0.2s ease;
    margin-bottom: 12px;
  }
  .email-input:focus { border-color: var(--tangerine); }
  .email-disclaimer {
    font-size: 12px;
    color: var(--text-muted);
    text-align: center;
    opacity: 0.75;
    line-height: 1.5;
    margin-top: 14px;
  }

  /* CONSENT CHECKBOX */
  .consent-wrap {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    background: rgba(155,231,219,0.12);
    border: 1.5px solid rgba(155,231,219,0.5);
    border-radius: 12px;
    padding: 14px 16px;
    margin-bottom: 16px;
    cursor: pointer;
    transition: border-color 0.2s ease;
  }
  .consent-wrap:hover { border-color: var(--tangerine); }
  .consent-wrap input[type="checkbox"] {
    appearance: none;
    -webkit-appearance: none;
    width: 20px;
    height: 20px;
    min-width: 20px;
    border: 2px solid rgba(0,0,0,0.2);
    border-radius: 6px;
    background: white;
    cursor: pointer;
    transition: all 0.2s ease;
    position: relative;
    margin-top: 1px;
  }
  .consent-wrap input[type="checkbox"]:checked {
    background: var(--tangerine);
    border-color: var(--tangerine);
  }
  .consent-wrap input[type="checkbox"]:checked::after {
    content: '';
    position: absolute;
    left: 5px;
    top: 2px;
    width: 6px;
    height: 10px;
    border: 2px solid white;
    border-top: none;
    border-left: none;
    transform: rotate(45deg);
  }
  .consent-text {
    font-size: 13px;
    line-height: 1.5;
    color: var(--dark-mid);
    font-weight: 500;
    cursor: pointer;
    user-select: none;
  }
  @media (max-width: 600px) {
    .consent-text { font-size: 12px; }
  }

  /* RESULTS */
  .score-ring-wrap {
    display: flex;
    justify-content: center;
    margin-bottom: 28px;
  }
  .score-ring {
    position: relative;
    width: 130px;
    height: 130px;
  }
  .score-ring svg { transform: rotate(-90deg); }
  .score-ring-value {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
  .score-number {
    font-family: 'DM Serif Display', serif;
    font-size: 46px;
    line-height: 1;
    color: var(--dark);
  }
  .score-of {
    font-size: 12px;
    color: var(--text-muted);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .result-name {
    font-family: 'DM Serif Display', serif;
    font-size: 26px;
    color: var(--tangerine);
    text-align: center;
    margin-bottom: 14px;
    font-style: italic;
  }
  .result-message {
    font-size: 15.5px;
    line-height: 1.7;
    color: var(--text-muted);
    text-align: center;
    margin-bottom: 24px;
  }

  .next-step-box {
    background: linear-gradient(135deg, rgba(243,132,60,0.08), rgba(255,106,64,0.06));
    border: 1.5px solid rgba(243,132,60,0.25);
    border-radius: 16px;
    padding: 20px 22px;
    margin-bottom: 24px;
  }
  .next-step-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--tangerine);
    margin-bottom: 6px;
  }
  .next-step-text {
    font-size: 15px;
    line-height: 1.6;
    color: var(--dark-mid);
    font-weight: 500;
  }

  .ethical-note {
    font-size: 11.5px;
    color: var(--text-muted);
    text-align: center;
    opacity: 0.6;
    line-height: 1.5;
    margin-top: 20px;
    padding-top: 18px;
    border-top: 1px solid rgba(0,0,0,0.06);
  }

  /* DIVIDER */
  .divider {
    height: 1px;
    background: rgba(0,0,0,0.06);
    margin: 24px 0;
  }

  /* RESPONSIVE */
  @media (max-width: 600px) {
    .card { padding: 36px 28px 32px; border-radius: 22px; }
    h1.display { font-size: 26px; }
    .question-text { font-size: 20px; min-height: 64px; }
  }

  /* SCREENS */
  .screen { display: none; }
  .screen.active { display: block; }

  /* HIDDEN form for ConvertKit */
  #ck-form { display: none; }
</style>
</head>
