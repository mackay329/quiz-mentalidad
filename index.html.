  {min:9,  max:10, nota:5},
  {min:11, max:12, nota:6},
  {min:13, max:14, nota:7},
  {min:15, max:16, nota:8},
  {min:17, max:18, nota:9},
  {min:19, max:21, nota:10}
];

const RESULTS = [
  {
    rango: [1,3],
    nombre: "Modo niebla",
    mensaje: "Tu cabeza ahora mismo no te está ayudando demasiado. No necesitas hacerlo perfecto: necesitas un ancla pequeña para hoy.",
    siguiente_paso: "Antes de buscar más información o técnicas, lo primero es encontrar ese punto fijo de tu día. Una sola acción concreta que te ancle. Eso es por donde empezamos juntos."
  },
  {
    rango: [4,6],
    nombre: "Aguantas, pero te drena",
    mensaje: "Vas tirando, pero tu mente sigue gastando demasiada energía. Ya no toca solo resistir: toca poner estructura.",
    siguiente_paso: "Resistir sin estructura acaba por agotar. El siguiente paso es construir un sistema mental sencillo que te sostenga también en los días difíciles. Eso es lo que trabajamos."
  },
  {
    rango: [7,8],
    nombre: "Buena base",
    mensaje: "Tu mentalidad ya te sostiene en varias cosas. El siguiente paso es reforzar los hábitos mentales que también funcionen en los días malos.",
    siguiente_paso: "Tienes recursos, pero todavía hay puntos donde te cuesta más. El trabajo ahora es afinar esos hábitos para que no dependan solo de los días buenos."
  },
  {
    rango: [9,10],
    nombre: "Dirección interna",
    mensaje: "Estás transitando esto con bastante dirección. Aun así, tu fortaleza crece más cuando no dependes solo de la fuerza de voluntad.",
    siguiente_paso: "La fortaleza real no es aguantar más: es necesitar menos esfuerzo para sostenerte. Hay un siguiente nivel que no requiere más sacrificio, sino más estructura interna."
  }
];

let currentQ = 0;
let scores = [];
let selectedOption = null;
let totalScore = 0;
let finalNote = 0;

function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  const card = document.getElementById('main-card');
  card.classList.remove('card-fade');
  void card.offsetWidth;
  card.classList.add('card-fade');

  // logos are inline SVGs
}

function startQuiz() {
  currentQ = 0;
  scores = [];
  showQuestion();
  showScreen('screen-question');
}

function showQuestion() {
  selectedOption = null;
  document.getElementById('btn-next').disabled = true;
  document.getElementById('q-current').textContent = currentQ + 1;
  const pct = Math.round((currentQ / 7) * 100);
  document.getElementById('q-percent').textContent = pct + '%';
  document.getElementById('q-bar').style.width = pct + '%';
  document.getElementById('q-text').textContent = QUESTIONS[currentQ];

  const optContainer = document.getElementById('q-options');
  optContainer.innerHTML = '';

  ANSWERS.forEach((ans, i) => {
    const btn = document.createElement('button');
    btn.className = 'option-btn';
    btn.innerHTML = `<span class="option-dot">${i === 0 ? '○' : i === 1 ? '◎' : i === 2 ? '●' : '★'}</span>${ans}`;
    btn.onclick = () => selectOption(i, btn);
    optContainer.appendChild(btn);
  });
}

function selectOption(value, btn) {
  document.querySelectorAll('.option-btn').forEach(b => b.classList.remove('selected'));
  btn.classList.add('selected');
  selectedOption = value;
  document.getElementById('btn-next').disabled = false;
}

function nextQuestion() {
  if (selectedOption === null) return;
  scores.push(selectedOption);

  if (currentQ < 6) {
    currentQ++;
    showQuestion();
    // animate progress
    const pct = Math.round(((currentQ) / 7) * 100);
    document.getElementById('q-percent').textContent = pct + '%';
    document.getElementById('q-bar').style.width = pct + '%';
    document.getElementById('q-current').textContent = currentQ + 1;
  } else {
    // Done with questions
    totalScore = scores.reduce((a, b) => a + b, 0);
    finalNote = convertScore(totalScore);
    showScreen('screen-email');
  }
}

function convertScore(raw) {
  for (const row of CONVERSION) {
    if (raw >= row.min && raw <= row.max) return row.nota;
  }
  return 10;
}

function getResult(nota) {
  return RESULTS.find(r => nota >= r.rango[0] && nota <= r.rango[1]) || RESULTS[3];
}

function validateLeadForm() {
  const emailVal = document.getElementById('email-input').value;
  const emailValid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailVal);
  const checkValid = document.getElementById('consent-check').checked;
  document.getElementById('btn-email').disabled = !(emailValid && checkValid);
}

function submitEmail() {
  const email = document.getElementById('email-input').value.trim();
  const checked = document.getElementById('consent-check').checked;
  if (!email || !checked) return;

  const formData = new FormData();
  formData.append('email_address', email);
  try {
    formData.append('fields[quiz_score]', finalNote);
    formData.append('fields[quiz_raw]', totalScore);
    formData.append('fields[quiz_name]', getResult(finalNote).nombre);
  } catch(e) { /* silent — don't break main submission */ }

  fetch('https://app.convertkit.com/forms/8879080/subscriptions', {
    method: 'POST',
    mode: 'no-cors',
    body: formData
  }).catch(() => { /* silent fail */ });

  showResult();
}

function showResult() {
  const result = getResult(finalNote);

  document.getElementById('result-score').textContent = finalNote;
  document.getElementById('result-name').textContent = result.nombre;
  document.getElementById('result-message').textContent = result.mensaje;
  document.getElementById('result-next-step').textContent = result.siguiente_paso;

  showScreen('screen-result');

  // Animate score ring
  setTimeout(() => {
    const circumference = 345.4;
    const offset = circumference - (finalNote / 10) * circumference;
    const circle = document.getElementById('score-circle');
    circle.style.transition = 'stroke-dashoffset 1.2s cubic-bezier(0.34,1.56,0.64,1)';
    circle.style.strokeDashoffset = offset;
  }, 200);
}

function ctaClick() {
  window.open('https://www.instagram.com/roger_jofre?igsh=MXFkbHVjZHoyZTd1Yw%3D%3D&utm_source=qr', '_blank');
}

function restartQuiz() {
  currentQ = 0;
  scores = [];
  selectedOption = null;
  document.getElementById('email-input').value = '';
  document.getElementById('consent-check').checked = false;
  document.getElementById('btn-email').disabled = true;
  showScreen('screen-welcome');
}


});
</script>
